# Copiá a .streamlit/secrets.toml (local) o Streamlit Cloud → Settings → Secrets

[oia]
# ID de la planilla vinculada a Google Forms (respuestas)
google_sheet_id = ""
google_sheet_gid = "0"
# Estudiantes convocados (para tasa de respuesta MDEIA_IA_ENCUESTA)
poblacion_objetivo_estudiantes = 0

# Opcional: reemplazar URLs de Google Forms sin tocar el código
[encuestas_forms]
# estudiante = "https://docs.google.com/forms/d/e/..."
# docente = "https://docs.google.com/forms/d/e/..."
# autoridad = "https://docs.google.com/forms/d/e/..."
# administracion = "https://docs.google.com/forms/d/e/..."
